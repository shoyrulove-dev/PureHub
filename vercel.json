{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd pwa && npm install && cd .. && python3 -m pip install -r requirements.txt",
  "buildCommand": "cd pwa && npm run build",
  "outputDirectory": "pwa/dist",
  "functions": {
    "api/index.py": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/admin",
      "destination": "/api/admin"
    },
    {
      "source": "/admin/:path*",
      "destination": "/api/admin/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
